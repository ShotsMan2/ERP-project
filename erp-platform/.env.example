# =============================================================================
# ERP Platform - Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# NEVER commit .env to version control.

# =============================================================================
# Application Settings
# =============================================================================
APP_NAME=ERP Platform
APP_ENV=development                    # development | staging | production
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-random-secret-key  # Generate with: openssl rand -hex 32
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
PROJECT_NAME=ERP Platform
VERSION=1.0.0

# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=erp_db
POSTGRES_USER=erp_user
POSTGRES_PASSWORD=erp_secret_2024
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_SERVER}:${POSTGRES_PORT}/${POSTGRES_DB}
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false                      # Set true to log all SQL queries

# =============================================================================
# Redis
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=erp_redis_secret
REDIS_DB=0
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}
REDIS_CACHE_TTL=300                     # Default cache TTL in seconds

# =============================================================================
# RabbitMQ
# =============================================================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=erp_user
RABBITMQ_PASSWORD=erp_rabbit_secret
RABBITMQ_VHOST=/
RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@${RABBITMQ_HOST}:${RABBITMQ_PORT}/${RABBITMQ_VHOST}

# =============================================================================
# Celery
# =============================================================================
CELERY_BROKER_URL=${RABBITMQ_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}
CELERY_TASK_TRACK_STARTED=true
CELERY_TASK_SOFT_TIME_LIMIT=300         # Task soft time limit in seconds
CELERY_TASK_TIME_LIMIT=600              # Task hard time limit in seconds
CELERY_MAX_RETRIES=3
CELERY_TASK_ACKS_LATE=true
CELERYD_CONCURRENCY=4

# =============================================================================
# Elasticsearch
# =============================================================================
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_URL=http://${ELASTICSEARCH_HOST}:${ELASTICSEARCH_PORT}
ELASTICSEARCH_INDEX_PREFIX=erp

# =============================================================================
# MinIO (S3-compatible Storage)
# =============================================================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_secret
MINIO_BUCKET=erp-files
MINIO_REGION=us-east-1
MINIO_SECURE=false
S3_ENDPOINT_URL=http://${MINIO_ENDPOINT}
AWS_ACCESS_KEY_ID=${MINIO_ACCESS_KEY}
AWS_SECRET_ACCESS_KEY=${MINIO_SECRET_KEY}

# =============================================================================
# JWT Authentication
# =============================================================================
JWT_SECRET_KEY=change-me-to-a-jwt-secret
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_PRIVATE_KEY_PATH=
JWT_PUBLIC_KEY_PATH=

# =============================================================================
# OAuth2 / SSO
# =============================================================================
OAUTH_ENABLED=false
OAUTH_PROVIDER=                          # google | azure | okta
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URL=http://localhost:3000/auth/callback

# =============================================================================
# Security
# =============================================================================
BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=12
PASSWORD_MAX_LENGTH=128
MFA_ENFORCED_FOR_ROLES=admin,super_admin
SESSION_TIMEOUT_MINUTES=15
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
RATE_LIMIT_DEFAULT=1000/minute
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_PASSWORD_RESET=3/minute

# =============================================================================
# Email / SMTP
# =============================================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@erp-platform.com
SMTP_USE_TLS=true

# =============================================================================
# SMS (Twilio)
# =============================================================================
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# =============================================================================
# Monitoring & Observability
# =============================================================================
SENTRY_DSN=
OPENTELEMETRY_ENABLED=false
OPENTELEMETRY_EXPORTER=jaeger
JAEGER_HOST=localhost
JAEGER_PORT=6831
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR
LOKI_ENABLED=false
LOKI_URL=http://localhost:3100

# =============================================================================
# Frontend
# =============================================================================
VITE_PORT=3001
VITE_API_URL=http://localhost:8000/api/v1
VITE_WEBSOCKET_URL=ws://localhost:8000/ws
VITE_APP_NAME=ERP Platform
VITE_SENTRY_DSN=

# =============================================================================
# Backup
# =============================================================================
BACKUP_S3_BUCKET=erp-backups
BACKUP_S3_PREFIX=postgres
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * *               # Daily at 2 AM (cron expression)

# =============================================================================
# Feature Flags
# =============================================================================
FEATURE_AI_ASSISTANT=false
FEATURE_WORKFLOW_AUTOMATION=true
FEATURE_MOBILE_PWA=true
FEATURE_EINVOICE=true
