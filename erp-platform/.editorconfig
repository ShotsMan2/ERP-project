root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 120

[*.{yml,yaml}]
indent_size = 2

[*.{json,jsonc}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
max_line_length = 80

[Makefile]
indent_style = tab
indent_size = 4

[Dockerfile]
indent_size = 4

[*.{ts,tsx,js,jsx}]
indent_size = 2

[*.css,*.scss]
indent_size = 2

[*.sql]
indent_size = 2

[*.tf]
indent_size = 2

[*.{sh,bash,zsh}]
indent_size = 2
